Bootstrap: docker
From: python:3.12-slim

%labels
    Author UltimateAdvisor
    Version v1.0

%environment
    export PYTHONPATH="/app/src:$PYTHONPATH"
    export PATH="/app/.venv/bin:$PATH"

%setup
    # Create the app directory in the container
    mkdir -p ${APPTAINER_ROOTFS}/app

%files
    # Copy project files into the container
    . /app

%post
    # 1. Install system dependencies (Node.js for frontend, curl for uv)
    apt-get update && apt-get install -y curl
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
    apt-get install -y nodejs
    npm install -g pnpm

    # 2. Build Frontend
    cd /app/frontend
    # Remove host node_modules to avoid architecture conflicts
    rm -rf node_modules
    pnpm install
    pnpm run build

    # 3. Setup Python Backend
    cd /app
    # Remove any virtual environment copied from the host to prevent conflicts
    rm -rf .venv
    curl -LsSf https://astral.sh/uv/install.sh | sh
    /root/.local/bin/uv sync

%runscript
    cd /app
    /root/.local/bin/uv run fastapi run src/main.py --host 0.0.0.0 --port 8000